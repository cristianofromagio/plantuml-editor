{
  "name": "plantuml-editor",
  "version": "1.0.0",
  "description": "A desktop PlantUML editor with live preview",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "bundle": "npx esbuild src/editor/editor-entry.js --bundle --minify --format=iife --outfile=src/renderer/editor-bundle.js",
    "build": "electron-builder --win",
    "pack": "electron-builder --win --dir",
    "test": "npx playwright test"
  },
  "author": "PlantUML Editor",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.plantuml-editor.app",
    "productName": "PlantUML Editor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "resources/plantuml.jar",
        "to": "plantuml.jar"
      }
    ],
    "files": [
      "src/**/*",
      "resources/**/*"
    ]
  }
}
