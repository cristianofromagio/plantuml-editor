{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "plantuml-editor",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeDevCommand": "npm run bundle",
    "beforeBuildCommand": "npm run bundle"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PlantUML Editor",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../resources/plantuml.jar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
